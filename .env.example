# .env.example - Template for environment configurations
# DO NOT ADD REAL API KEYS OR PASSWORDS TO THIS FILE
# Copy this file to .env.dev, .env.uat, or .env.prod and fill in the values

GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
TAVILY_API_KEY=your_tavily_api_key_here

LLM_FAILOVER_CHAIN=gemini,openai,anthropic

# Redis Cache Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL=86400
CACHE_ENABLED=true

# PostgreSQL Analytics Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=detective_analytics
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password_here@postgres:5432/detective_analytics
